PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Firebase Service Account JSON (server-side only)
# Recommended for production: use Google Cloud Secret Manager or Workload Identity instead
# FIREBASE_SERVICE_ACCOUNT='{...}'

# Google Maps API key — SERVER key (restrict to server IP + Routes API in GCP Console)
# Keep this DIFFERENT from the NEXT_PUBLIC_GOOGLE_MAPS_API_KEY in the frontend
GOOGLE_MAPS_API_KEY=your_server_side_routes_api_key_here

# Admin API secret — protects compute-polyline and other admin-only endpoints
# Generate with: openssl rand -hex 32
# MUST match ADMIN_API_SECRET in frontend/.env.local (used by the server-side proxy)
ADMIN_API_SECRET=change_me_to_a_long_random_string

# ETA computation interval in milliseconds (default: 180000 = 3 minutes)
# Lower = more accurate ETAs but higher Google Routes API costs
ETA_INTERVAL_MS=180000
